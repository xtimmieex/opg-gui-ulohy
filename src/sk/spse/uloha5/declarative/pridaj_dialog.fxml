<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="sk.spse.uloha5.declarative.PridajController"
      spacing="15" prefWidth="300">
    <padding>
        <Insets topRightBottomLeft="20"/>
    </padding>

    <Label text="Pridať novú potravinu" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">
        <Label text="Názov:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="nazovField" promptText="Názov jedla"
                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Kalórie:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="kalorieField" promptText="napr. 250"
                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Cena (€):" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="cenaField" promptText="napr. 1.99"
                   GridPane.rowIndex="2" GridPane.columnIndex="1"/>
    </GridPane>

    <Label fx:id="chybaLabel" style="-fx-text-fill: red;" text="" wrapText="true"/>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button text="Pridaj" onAction="#potvrdit" defaultButton="true"
                style="-fx-base: #4CAF50; -fx-text-fill: white;"/>
        <Button text="Zruš" onAction="#zrusit" cancelButton="true"/>
    </HBox>
</VBox>
