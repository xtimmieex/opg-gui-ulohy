<?xml version="1.0" encoding="UTF-8"?>

        <?import javafx.geometry.Insets?>
        <?import javafx.scene.control.Button?>
        <?import javafx.scene.control.Label?>
        <?import javafx.scene.control.TableColumn?>
        <?import javafx.scene.control.TableView?>
        <?import javafx.scene.layout.BorderPane?>
        <?import javafx.scene.layout.HBox?>

<BorderPane stylesheets="@style.css" xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="sk.spse.uloha5.declarative.Controller">
    <padding>
        <Insets topRightBottomLeft="15"/>
    </padding>
    <top>
        <Label text="Zoznam potravín" style="-fx-font-size: 18px;" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets bottom="10"/>
            </BorderPane.margin>
        </Label>
    </top>
    <center>
        <TableView id="table" fx:id="tabulka">
            <columns >
                <TableColumn fx:id="id" text="ID" prefWidth="50"/>
                <TableColumn fx:id="nazovJedal" text="Názov" prefWidth="150"/>
                <TableColumn fx:id="kalorie" text="Kalórie" prefWidth="100"/>
                <TableColumn fx:id="cena" text="Cena"/>
            </columns>
        </TableView>
    </center>
    <bottom>
        <HBox id="Hbox" alignment="CENTER_RIGHT" spacing="10">
            <BorderPane.margin>
                <Insets top="10"/>
            </BorderPane.margin>
            <Button id="button" text="Pridaj potravinu" onAction="#pridaj"/>
            <Button id="button" text="Vymaž" onAction="#vymaz"/>
            <Button id="button" text="Zatvor" onAction="#close"/>
        </HBox>
    </bottom>
</BorderPane>