<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox id="Vbox" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sk.spse.uloha1.declarative.Controller">
   <children>
      <HBox alignment="CENTER_RIGHT" spacing="10.0">
      
          <padding>
              <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
          </padding>
      
          <Label alignment="CENTER_RIGHT" contentDisplay="RIGHT" text="Stupne Celsia:" textAlignment="RIGHT" />
      
          <TextField fx:id="cField" onKeyTyped="#onCelsiusChange" style="-fx-padding: 10 20 10 20;" text="0" />
         <Label text="C" />
      </HBox>
      <HBox alignment="CENTER_RIGHT" layoutX="10.0" layoutY="10.0" spacing="10.0">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <Label alignment="CENTER_RIGHT" contentDisplay="RIGHT" text="Stupne Fahrenheita: " textAlignment="RIGHT" />
            <TextField fx:id="fField" onKeyTyped="#onFahrenheitChange" style="-fx-padding: 10 20 10 20;" text="0" />
            <Label text="F" />
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</VBox>
